PORT=5000
NODE_ENV=development

DATABASE_URL = pooled Neon connection
DIRECT_URL   = direct Neon connection

GEMINI_API_KEY="paste_your_real_api_key_here"
GEMINI_MODEL="gemini-3.1-flash-lite"
AI_TIMEOUT_MS="15000"
AI_MANUAL_REVIEW_THRESHOLD="0.60"

DUPLICATE_THRESHOLD="0.62"
DUPLICATE_LOOKBACK_HOURS="48"
DUPLICATE_CANDIDATE_LIMIT="100"
DUPLICATE_MIN_LOCATION_SIMILARITY="0.35"
DUPLICATE_MIN_DESCRIPTION_SIMILARITY="0.25"

JWT_SECRET="replace_with_a_long_random_secret"
JWT_EXPIRES_IN_SECONDS="7200"
JWT_ISSUER="crisisdesk-ai"
JWT_AUDIENCE="crisisdesk-admin"

ADMIN_NAME="CrisisDesk Super Admin"
ADMIN_EMAIL="admin@crisisdesk.local"
ADMIN_PASSWORD="password1234"

CORS_ORIGINS="http://localhost:3000,http://localhost:5173"