    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login returns status 200\", function () {\r",
              "  pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const responseBody = pm.response.json();\r",
              "\r",
              "pm.test(\"Login response contains an access token\", function () {\r",
              "  pm.expect(responseBody).to.have.nested.property(\r",
              "    \"data.accessToken\"\r",
              "  );\r",
              "\r",
              "  pm.expect(responseBody.data.accessToken)\r",
              "    .to.be.a(\"string\")\r",
              "    .and.not.be.empty;\r",
              "});\r",
              "\r",
              "/*\r",
              " * Save the JWT as a collection variable.\r",
              " * It will be available to the other requests\r",
              " * in this collection as {{adminToken}}.\r",
              " */\r",
              "if (\r",
              "  pm.response.code === 200 &&\r",
              "  responseBody?.data?.accessToken\r",
              ") {\r",
              "  pm.collectionVariables.set(\r",
              "    \"adminToken\",\r",
              "    responseBody.data.accessToken\r",
              "  );\r",
              "\r",
              "  console.log(\r",
              "    \"Administrator token saved successfully.\"\r",
              "  );\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
